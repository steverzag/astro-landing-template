---
import Layout from "./Layout.astro";

interface Props {
    title: string;
    lastUpdated?: string;
}

const { title, lastUpdated } = Astro.props;
---

<Layout title={title}>
    <article class="mx-auto max-w-3xl px-6 py-20">
        <h1 class="font-heading text-4xl font-bold text-primary">{title}</h1>
        {
            lastUpdated && (
                <p class="mt-2 font-body text-sm text-secondary">
                    Last updated: {lastUpdated}
                </p>
            )
        }
        <div
            class="mt-10 font-body text-base text-secondary [&_a]:text-primary [&_a]:underline [&_h2]:mt-10 [&_h2]:font-heading [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-primary [&_h3]:mt-8 [&_h3]:font-heading [&_h3]:text-lg [&_h3]:font-bold [&_h3]:text-primary [&_li]:mt-2 [&_ol]:mt-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:mt-4 [&_strong]:text-primary [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6"
        >
            <slot />
        </div>
    </article>
</Layout>
