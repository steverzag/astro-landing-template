---
import Layout from "./Layout.astro";

interface Props {
    title: string;
    lastUpdated?: string;
}

const { title, lastUpdated } = Astro.props;
---

<Layout title={title}>
    <article class="mx-auto max-w-3xl px-6 py-20">
        <h1 class="font-heading text-4xl font-bold text-primary">{title}</h1>
        {
            lastUpdated && (
                <p class="mt-2 font-body text-sm text-secondary">
                    Last updated: {lastUpdated}
                </p>
            )
        }
        <div class="mt-10 space-y-6 font-body text-base text-secondary [&_h2]:font-heading [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-primary">
            <slot />
        </div>
    </article>
</Layout>
