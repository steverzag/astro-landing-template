---
import Layout from "@layouts/Layout.astro";
---

<Layout title="404 - Page Not Found">
    <div class="flex min-h-screen flex-col items-center justify-center gap-6 px-6 py-20 text-center">
        <h1 class="font-heading text-4xl font-bold text-primary md:text-6xl">
            404 - Page Not Found
        </h1>
        <p class="mx-auto max-w-2xl font-body text-lg text-secondary">
            Oops! The page you are looking for does not exist.
        </p>
        <a
            href="/"
            class="rounded-md bg-primary px-6 py-3 font-body text-sm text-background shadow-md transition hover:bg-primary/85 active:scale-[0.98]"
        >
            Go back home
        </a>
    </div>
</Layout>

