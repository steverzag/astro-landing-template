---
import { getEntry, render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import ServiceHero from "@sections/services/ServiceHero.astro";
import ServiceContent from "@sections/services/ServiceContent.astro";

// One page per markdown file in the `services` collection. The file id (its
// filename without extension) is the URL slug: /services/<slug>. Rendered on
// demand (the site runs in `output: "server"` mode, like the legal pages).
const { slug } = Astro.params;
const service = slug ? await getEntry("services", slug) : undefined;
if (!service) {
    return new Response(null, { status: 404, statusText: "Not found" });
}
const { Content } = await render(service);
---

<Layout title={service.data.title}>
    <ServiceHero title={service.data.title} description={service.data.description} />
    <ServiceContent>
        <Content />
    </ServiceContent>
</Layout>
