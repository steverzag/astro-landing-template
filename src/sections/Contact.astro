---
// Contact section — a simple lead-capture form.
// Wire `action` to your form handler / endpoint when ready.
import Reveal from "@components/Reveal.astro";
import ContactUsForm from "@components/Forms/ContactUsForm.astro";
const heading = "Get in Touch";
const subheading = "Tell us about your project and we'll get back to you shortly.";
---

<section id="contact" class="scroll-mt-20 border-t border-tertiary bg-background">
    <div class="py-20">
        <Reveal class="mx-auto max-w-2xl animate-fade-up">
        <div class="text-center">
            <h2 class="font-heading text-3xl font-bold text-primary md:text-4xl">
                {heading}
            </h2>
            <p class="mt-4 font-body text-base text-secondary">{subheading}</p>
        </div>

        <ContactUsForm />
        </Reveal>
    </div>
</section>
