---
// About section — who you are and what you stand for.
const heading = "About Us";
const body =
    "Use this space to tell your story. Explain your mission, what makes you different, and why visitors should trust you. Keep it concise and focused on the value you bring.";

const stats = [
    { value: "10+", label: "Years of experience" },
    { value: "500+", label: "Happy clients" },
    { value: "99%", label: "Satisfaction rate" },
];
---

<section id="about" class="scroll-mt-20 bg-background">
    <div class="mx-auto max-w-7xl px-6 py-20">
        <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2">
            <div>
                <h2 class="font-heading text-3xl font-bold text-primary md:text-4xl">
                    {heading}
                </h2>
                <p class="mt-6 font-body text-base text-secondary">{body}</p>
            </div>
            <dl class="grid grid-cols-3 gap-6">
                {
                    stats.map((stat) => (
                        <div class="rounded-lg border border-tertiary p-6 text-center shadow-sm">
                            <dt class="font-heading text-3xl font-bold text-primary">
                                {stat.value}
                            </dt>
                            <dd class="mt-2 font-body text-sm text-secondary">
                                {stat.label}
                            </dd>
                        </div>
                    ))
                }
            </dl>
        </div>
    </div>
</section>
