---
// Services section — what you offer, as a grid of cards.
const heading = "Our Services";
const subheading = "A short line introducing the range of what you provide.";

const services = [
    {
        title: "Service One",
        description:
            "Describe the service and the problem it solves for your customer in a sentence or two.",
    },
    {
        title: "Service Two",
        description:
            "Describe the service and the problem it solves for your customer in a sentence or two.",
    },
    {
        title: "Service Three",
        description:
            "Describe the service and the problem it solves for your customer in a sentence or two.",
    },
];
---

<section id="services" class="scroll-mt-20 border-t border-tertiary bg-background">
    <div class="mx-auto max-w-7xl px-6 py-20">
        <div class="mx-auto max-w-2xl text-center">
            <h2 class="font-heading text-3xl font-bold text-primary md:text-4xl">
                {heading}
            </h2>
            <p class="mt-4 font-body text-base text-secondary">{subheading}</p>
        </div>
        <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
            {
                services.map((service) => (
                    <article class="rounded-lg border border-tertiary p-8 shadow-sm transition-shadow hover:shadow-md">
                        <h3 class="font-heading text-xl font-bold text-primary">
                            {service.title}
                        </h3>
                        <p class="mt-3 font-body text-sm text-secondary">
                            {service.description}
                        </p>
                    </article>
                ))
            }
        </div>
    </div>
</section>
