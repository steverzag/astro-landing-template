---
// Services section — what you offer, as a grid of cards. Each card is sourced
// from the `services` content collection and links to its own detail page at
// /services/<id>. Add a markdown file under src/content/services/ to add a card.
import { getCollection } from "astro:content";
import RevealStagger from "@components/RevealStagger.astro";
import Reveal from "@components/Reveal.astro";
const heading = "Our Services";
const subheading = "A short line introducing the range of what you provide.";

const services = (await getCollection("services")).sort(
    (a, b) => a.data.order - b.data.order,
);
---

<section id="services" class="scroll-mt-20 border-t border-tertiary bg-background">
    <div class="py-20">
        <Reveal class="mx-auto max-w-2xl animate-fade-up text-center">
            <h2 class="font-heading text-3xl font-bold text-primary md:text-4xl">
                {heading}
            </h2>
            <p class="mt-4 font-body text-base text-secondary">{subheading}</p>
        </Reveal>
        <RevealStagger class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
            {
                services.map((service) => (
                    <a
                        href={`/services/${service.id}`}
                        class="group animate-fade-up rounded-lg border border-tertiary p-8 shadow-sm transition-shadow hover:shadow-md"
                    >
                        <h3 class="font-heading text-xl font-bold text-primary">
                            {service.data.title}
                        </h3>
                        <p class="mt-3 font-body text-sm text-secondary">
                            {service.data.description}
                        </p>
                        <span class="mt-4 inline-block font-body text-sm font-bold text-primary transition-opacity group-hover:opacity-muted">
                            Learn more &rarr;
                        </span>
                    </a>
                ))
            }
        </RevealStagger>
    </div>
</section>
