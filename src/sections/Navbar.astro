---
import Modal from "@components/Modal.astro";
import ContactUsForm from "@components/Forms/ContactUsForm.astro";

// Generic navigation bar for the landing page template.
// Edit `links` to match your site's pages.
const links = [
  { label: "Home", href: "/" },
  { label: "About Us", href: "/#about" },
  { label: "Services", href: "/#services" },
  { label: "Contact", href: "/#contact" },
];

const brand = "Brand";
---

<header
  class="sticky top-0 z-50 w-full border-b border-tertiary bg-background/80 backdrop-blur-md"
>
  <nav class="flex items-center justify-between py-4">
    <a href="/" class="font-heading text-xl font-bold text-primary">{brand}</a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-body text-sm text-primary transition-opacity hover:opacity-muted"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <Modal
      id="get-started-modal"
      title="Get Started"
      showCloseButton={true}
      closeOnOutsideClick={true}
      openBtnClass="hidden md:inline-block"
    >
      <span
        slot="open-button-content"
        class="hidden rounded-md bg-primary px-4 py-2 font-body text-sm text-background shadow-sm transition hover:bg-primary/85 active:scale-[0.98] md:inline-block"
      >
        Get Started
      </span>
      <div slot="main">
        <ContactUsForm />
      </div>
    </Modal>

    <!-- Mobile menu toggle. Padding + negative margin grow the 24px icon to a
         44px touch target without shifting the layout. The icon swaps to an X
         while open, driven purely by aria-expanded (group-aria-expanded:). -->
    <button
      type="button"
      id="nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
      class="group -m-2.5 p-2.5 md:hidden"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-6 text-primary group-aria-expanded:hidden"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
      </svg>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="hidden size-6 text-primary group-aria-expanded:block"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18 18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile links -->
  <ul
    id="nav-mobile"
    class="hidden flex-col gap-1 border-t border-tertiary px-6 py-4 md:hidden"
  >
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class="block py-2 font-body text-sm text-primary transition-opacity hover:opacity-muted"
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</header>

<script>
  // Wired on astro:page-load so the (freshly swapped-in) header keeps working
  // after ClientRouter navigations — bundled scripts only execute once.
  document.addEventListener("astro:page-load", () => {
    const toggle = document.getElementById("nav-toggle");
    const menu = document.getElementById("nav-mobile");

    const setOpen = (open: boolean) => {
      menu?.classList.toggle("hidden", !open);
      toggle?.setAttribute("aria-expanded", String(open));
    };

    toggle?.addEventListener("click", () =>
      setOpen(menu?.classList.contains("hidden") ?? false),
    );

    // Tapping a link should dismiss the menu instead of leaving it open over
    // the section it just scrolled to.
    menu?.addEventListener("click", (event) => {
      if (event.target instanceof Element && event.target.closest("a"))
        setOpen(false);
    });
  });
</script>

<style>
  @reference "../styles/global.css";

  /* Animate the mobile menu open/close. `display` rides along via
     allow-discrete so the exit fade finishes before the element leaves the
     layout; @starting-style provides the entry keyframe. The `hidden` utility
     still owns the actual display value. */
  #nav-mobile {
    transition-property: display, opacity, translate;
    transition-duration: var(--transition-duration-fast);
    transition-timing-function: var(--ease-out);
    transition-behavior: allow-discrete;
  }

  #nav-mobile.hidden {
    opacity: 0;
    translate: 0 -0.5rem;
  }

  @starting-style {
    #nav-mobile:not(.hidden) {
      opacity: 0;
      translate: 0 -0.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #nav-mobile,
    #nav-mobile.hidden {
      translate: none;
    }
  }
</style>
